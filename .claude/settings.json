{
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "0",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "",
    "CLAUDE_CODE_SUBAGENT_MODEL": ""
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q 'feeds.yaml' && uv run python $CLAUDE_PROJECT_DIR/.claude/hooks/sync_feeds_readme.py 2>/dev/null || true",
            "statusMessage": "Syncing feeds to README..."
          }
        ]
      }
    ]
  }
}
